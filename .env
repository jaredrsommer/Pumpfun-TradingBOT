SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WALLET_PRIVATE_KEY=

MIN_LIQUIDITY=25000
MAX_MARKET_CAP=750000
TARGET_MARKET_CAP_TO_SCAN=30000
MIN_TRANSACTIONS=75
MAX_TOKEN_AGE_HOURS=6

STOP_LOSS_PERCENTAGE=12.0
TRAILING_STOP_LOSS_PERCENTAGE=5.0
MAX_POSITION_SIZE=0.03
TAKE_PROFIT_LEVELS=[1.5,2,3,5]

VOLUME_SPIKE_THRESHOLD=2.5
MIN_BUY_SELL_RATIO=0.65

MIN_HOLDER_COUNT=100

DEXSCREENER_SEARCH_API=https://api.dexscreener.com/latest/dex
DEXSCREENER_TOKEN_PROFILES_API=https://api.dexscreener.com/token-profiles/latest/v1
RUGCHECK_API_ENDPOINT=https://api.rugcheck.xyz/v1/tokens

STATIC_RUGCHECK_JWT=
RUGCHECK_SCORE_THRESHOLD=10
RUGCHECK_CRITICAL_RISK_NAMES=Honeypot,RugpullHistory,ProxyContract,UnverifiedSourceCode,MintAuthorityEnabled,FreezeAuthorityEnabled,MutableMetadata,HighPrivilegedFunctions

FILTER_FOR_PUMPFUN_ONLY=true
PUMPFUN_ADDRESS_SUFFIX=pump

TRADER_MAX_POSITION_SIZE=0.1
TRADER_DEFAULT_TAKE_PROFIT_PCT=0.15

MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9
BOLLINGER_WINDOW=20
BOLLINGER_STD_DEV=2

RUGCHECK_AUTH_SOLANA_PRIVATE_KEY=
RUGCHECK_AUTH_WALLET_PUBLIC_KEY=

DRY_RUN=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
